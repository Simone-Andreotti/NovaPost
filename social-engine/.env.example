# Required
NVIDIA_NIM_API_KEY=

# Optional model overrides
NVIDIA_NIM_MODEL=meta/llama-3.1-405b-instruct
NVIDIA_NIM_VISION_MODEL=meta/llama-3.2-90b-vision-instruct

# TTS backend: auto | elevenlabs | edge | kokoro
TTS_BACKEND=auto

# Edge TTS
TTS_EDGE_VOICE=en-US-ChristopherNeural
TTS_EDGE_RATE=+0%
TTS_EDGE_PITCH=+4Hz
TTS_EDGE_VOLUME=+0%

# Subtitle tuning
TTS_SUBTITLE_WORDS_PER_CHUNK=4
TTS_SUBTITLE_MARGIN_V=180
TTS_SUBTITLE_MARGIN_L=54
TTS_SUBTITLE_FONT_SIZE=34
TTS_SUBTITLE_FONT_NAME=Syncopate
TTS_SUBTITLE_ALIGNMENT=2

# ElevenLabs (optional)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=ErXwobaYiN019PkySvjV
ELEVENLABS_MODEL_ID=eleven_v3
ELEVENLABS_STABILITY=0.35
ELEVENLABS_SIMILARITY_BOOST=0.78
ELEVENLABS_STYLE=0.32
ELEVENLABS_SPEAKER_BOOST=true

# Kokoro (optional local fallback)
TTS_KOKORO_VOICE=am_fenrir
TTS_KOKORO_LANG=en-us
TTS_KOKORO_SPEED=1.02

# Optional behavior controls
SLIDER_VARIATION_SEED=
LINKEDIN_REREAD_ENABLED=false
